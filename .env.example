# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CMS Configuration (Local JSON mode)
# Установите true для использования JSON вместо БД
VITE_LOCAL_CMS_ENABLED=true
# URL CMS сервера (оставьте пустым для использования Vite Proxy)
VITE_CMS_API_URL=
# Секретный токен для доступа к CMS через ngrok
CMS_SECRET_TOKEN=change_this_secret_token

# Cloudinary (Опционально)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=